{
  "name": "full-project-skill",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:build": "bun scripts/build-docs.ts --target all --mode write",
    "docs:check": "bun scripts/build-docs.ts --target all --mode check",
    "contract:check": "bun scripts/verify-skill.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "verify": "bun run contract:check && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "typescript": "^5.7.3"
  }
}

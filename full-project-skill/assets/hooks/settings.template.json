{
  "$schema": "hooks-template.v1",
  "$description": "Claude Code hooks template for projects generated by full-project-skill skill. Variables use {{VARIABLE}} syntax and are substituted by the skill during hook installation.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "$id": "prompt-submit-guards",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/prompt-guard.sh" },
          { "type": "command", "command": "bash .claude/hooks/phase-tracker.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "$id": "pre-commit-lint-typecheck",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE 'git\\s+commit'; then cd \"$CLAUDE_PROJECT_DIR\" && {{PM}} run lint && {{PM}} run typecheck; fi",
            "timeout": 60,
            "statusMessage": "Running lint + typecheck before commit..."
          }
        ]
      },
      {
        "$id": "pre-push-test",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE 'git\\s+push'; then cd \"$CLAUDE_PROJECT_DIR\" && {{PM}} run test; fi",
            "timeout": 120,
            "statusMessage": "Running tests before push..."
          }
        ]
      },
      {
        "$id": "pre-write-guards",
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/worktree-guard.sh" },
          { "type": "command", "command": "bash .claude/hooks/tdd-guard-hook.sh" },
          { "type": "command", "command": "bash .claude/hooks/pre-code-change.sh" },
          { "type": "command", "command": "bash .claude/hooks/plan-gate.sh" },
          { "type": "command", "command": "bash .claude/hooks/research-gate.sh" }
        ]
      },
      {
        "$id": "immutable-layer-guard",
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE 'docs/(architecture|implement)\\.md'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"This file is in the immutable layer. Confirm with the user before modifying.\"}}'; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "$id": "post-write-guards",
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/anti-simplification.sh" },
          { "type": "command", "command": "bash .claude/hooks/doc-drift-guard.sh" },
          { "type": "command", "command": "bash .claude/hooks/atomic-pending.sh" }
        ]
      },
      {
        "$id": "plan-sync-guard",
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q 'plans.md'; then echo '{\"systemMessage\":\"Reminder: docs/plans.md was modified. Keep docs/documentation.md milestone status in sync.\"}'; fi",
            "timeout": 5
          }
        ]
      },
      {
        "$id": "post-bash-guards",
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/post-bash.sh" },
          { "type": "command", "command": "bash .claude/hooks/atomic-commit.sh" }
        ]
      },
      {
        "$id": "context-pressure-monitor",
        "matcher": ".*",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/context-pressure-hook.sh" }]
      }
    ],
    "Stop": [
      {
        "$id": "session-end-reminder",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/tasks/todo.md\" ] && grep -q '\\- \\[ \\]' \"$CLAUDE_PROJECT_DIR/tasks/todo.md\"; then echo '{\"systemMessage\":\"Session ending with unchecked tasks in tasks/todo.md. Follow Session Handoff Protocol: update task status, note in-progress context, run verification, create WIP commit.\"}'; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "$variables": {
    "PM": {
      "description": "Package manager command (e.g., bun, pnpm, npm)",
      "default": "bun"
    }
  }
}

{
  "$schema": "hooks-template.codex.v1",
  "$description": "Codex CLI hooks template for projects generated by full-project-skill skill. Maps the same hook scripts to Codex CLI event format.",
  "hooks": {
    "on_agent_message": [
      {
        "$id": "prompt-submit-guards",
        "hooks": [
          { "type": "command", "command": "bash .codex/hooks/prompt-guard.sh" },
          { "type": "command", "command": "bash .codex/hooks/phase-tracker.sh" }
        ]
      }
    ],
    "pre_tool_call": [
      {
        "$id": "pre-commit-lint-typecheck",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/pre-commit-lint.sh",
            "timeout": 60
          }
        ]
      },
      {
        "$id": "pre-push-test",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/pre-push-test.sh",
            "timeout": 120
          }
        ]
      },
      {
        "$id": "pre-write-guards",
        "hooks": [
          { "type": "command", "command": "bash .codex/hooks/worktree-guard.sh" },
          { "type": "command", "command": "bash .codex/hooks/tdd-guard-hook.sh" },
          { "type": "command", "command": "bash .codex/hooks/pre-code-change.sh" },
          { "type": "command", "command": "bash .codex/hooks/plan-gate.sh" },
          { "type": "command", "command": "bash .codex/hooks/research-gate.sh" }
        ]
      },
      {
        "$id": "immutable-layer-guard",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/immutable-layer-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "post_tool_call": [
      {
        "$id": "post-write-guards",
        "hooks": [
          { "type": "command", "command": "bash .codex/hooks/anti-simplification.sh" },
          { "type": "command", "command": "bash .codex/hooks/doc-drift-guard.sh" },
          { "type": "command", "command": "bash .codex/hooks/atomic-pending.sh" },
          { "type": "command", "command": "bash .codex/hooks/plan-sync-reminder.sh" }
        ]
      },
      {
        "$id": "post-bash-guards",
        "hooks": [
          { "type": "command", "command": "bash .codex/hooks/post-bash.sh" },
          { "type": "command", "command": "bash .codex/hooks/atomic-commit.sh" }
        ]
      },
      {
        "$id": "context-pressure-monitor",
        "hooks": [{ "type": "command", "command": "bash .codex/hooks/context-pressure-hook.sh" }]
      }
    ],
    "on_session_end": [
      {
        "$id": "session-end-reminder",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/session-end-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "$variables": {
    "PM": {
      "description": "Package manager command (e.g., bun, pnpm, npm)",
      "default": "bun"
    }
  }
}

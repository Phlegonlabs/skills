#!/bin/sh
set -eu

bootstrap_window_open() {
  set -- harnass-os/documents/plans/*.yaml
  if [ -e "$1" ]; then
    return 1
  fi

  set -- harnass-os/documents/runs/history/bootstrap-*.yaml
  [ -e "$1" ]
}

# ---------------------------------------------------------------------------
# Lint staged files if the project has a lint command configured.
# The lint command is discovered from package.json scripts during planning
# and stored in harnass-os/documents/inventory/current-state.yaml.
#
# To enable staged-file lint, uncomment and fill the command below:
# ${lint_command} --staged
# ---------------------------------------------------------------------------

if bootstrap_window_open; then
  exit 0
fi

# Keep the repo lifecycle state synchronized before guard checks run.
python harnass-os/scripts/orchestrator.py tick --stage

# Guard checks — these enforce harness gates
python harnass-os/scripts/agent-guard.py check-plan-gate
python harnass-os/scripts/agent-guard.py record-task-change
python harnass-os/scripts/agent-guard.py check-task-sync
python harnass-os/scripts/agent-guard.py check-task-fields
python harnass-os/scripts/agent-guard.py check-write-scope-overlap

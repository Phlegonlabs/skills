#!/bin/sh
set -eu

bootstrap_window_open() {
  set -- harnass-os/documents/plans/*.yaml
  if [ -e "$1" ]; then
    return 1
  fi

  set -- harnass-os/documents/runs/history/bootstrap-*.yaml
  [ -e "$1" ]
}

has_task_handoffs() {
  set -- harnass-os/documents/handoffs/*.yaml
  [ -e "$1" ]
}

deploy_started() {
  [ -f harnass-os/documents/deploy/current.yaml ] || return 1
  ! grep -Eq '^status:[[:space:]]*draft$' harnass-os/documents/deploy/current.yaml
}

# ---------------------------------------------------------------------------
# Run test and build commands before push if configured.
# Commands are discovered from package.json during planning
# and stored in harnass-os/documents/inventory/current-state.yaml.
#
# To enable, uncomment and fill the commands below:
# ${test_command}
# ${build_command}
# ---------------------------------------------------------------------------

if bootstrap_window_open; then
  exit 0
fi

# Guard checks — these enforce harness gates
python harnass-os/scripts/agent-guard.py check-execution-ready
python harnass-os/scripts/agent-guard.py check-task-deps
python harnass-os/scripts/agent-guard.py check-validation-complete

if has_task_handoffs; then
  python harnass-os/scripts/agent-guard.py check-handoff-ready
fi

if deploy_started; then
  python harnass-os/scripts/agent-guard.py check-deployment-ready
fi

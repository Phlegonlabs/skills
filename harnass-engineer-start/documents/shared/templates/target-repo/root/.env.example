# =============================================================================
# Environment Variable Template
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in your values before deploying.
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# This file (.env.example) is committed and serves as the source of truth
# for what variables are required.
# =============================================================================

# --- App ---
APP_NAME=<fill>
APP_ENV=development          # development | preview | production
APP_URL=<fill>               # e.g. https://your-app.example.com
APP_SECRET=<fill>            # random secret key for session/CSRF signing

# --- Database ---
DATABASE_URL=<fill>          # e.g. postgresql://user:password@host:5432/dbname

# --- Auth ---
AUTH_SECRET=<fill>           # secret used to sign auth tokens / JWTs
AUTH_URL=<fill>              # base URL for OAuth redirect (same as APP_URL in prod)

# --- Third-party API keys ---
# Add the API keys your project actually uses.
# Remove sections that are not applicable.

# OpenAI
OPENAI_API_KEY=<fill>

# Stripe
STRIPE_PUBLIC_KEY=<fill>
STRIPE_SECRET_KEY=<fill>
STRIPE_WEBHOOK_SECRET=<fill>

# SendGrid / Email
SENDGRID_API_KEY=<fill>
EMAIL_FROM=<fill>

# Cloudflare (if deploying to Cloudflare Pages/Workers)
CLOUDFLARE_API_TOKEN=<fill>
CLOUDFLARE_ACCOUNT_ID=<fill>

# AWS (if applicable)
AWS_ACCESS_KEY_ID=<fill>
AWS_SECRET_ACCESS_KEY=<fill>
AWS_REGION=<fill>

# --- Feature flags ---
FEATURE_FLAG_EXAMPLE=false

# =============================================================================
# HOW TO DEPLOY
# After filling in this file as .env, follow Deploy.md to run deploy commands
# manually. The agent will NOT deploy on your behalf — you deploy when ready.
# =============================================================================
